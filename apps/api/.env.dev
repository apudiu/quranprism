# Dev env for the api workspace (and the postgres service it points at).
# Safe to commit — only dev-tier values. Staging + prod live alongside
# as .env.stg / .env.live (placeholder values; real secrets land via
# Kubernetes Secret in production, not from this file).

# --- Postgres -----------------------------------------------------
# Lives here because the api's DATABASE_URL below encodes the same
# credentials — keeping them in one file makes the api and the
# postgres service share a single source of truth in dev. The compose
# postgres service references this same file via env_file.
POSTGRES_USER=qp
POSTGRES_PASSWORD=qp_dev
POSTGRES_DB=qp

# --- App env selector --------------------------------------------
APP_ENV=development

# --- API listener ------------------------------------------------
PORT=3000

# --- API datastores (compose-internal hostnames) -----------------
DATABASE_URL=postgres://qp:qp_dev@postgres:5432/qp?sslmode=disable
REDIS_URL=redis://redis:6379/0
NATS_URL=nats://nats:4222

# --- JWT rotating-secret list (position 0 is the current signer) -
JWT_SECRETS=dev_jwt_secret_change_me_in_prod
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# --- Mailer (points at the dev Mailpit SMTP listener) ------------
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=none
MAILER_FROM=no-reply@quranprism.local

# --- Email link base (verification + reset URLs the api emits) ---
APP_BASE_URL=http://localhost:3002

# --- Go build (container only — VCS info isn't available inside the bind mount) ---
GOFLAGS=-buildvcs=false

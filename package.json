{
  "name": "quranprism",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/admin",
    "pkg/*"
  ],
  "scripts": {
    "dev:web": "bun --filter @qp/web dev",
    "dev:admin": "bun --filter @qp/admin dev",
    "build:web": "bun --filter @qp/web build",
    "build:admin": "bun --filter @qp/admin build",
    "build:all": "bun run build:web && bun run build:admin",
    "lint": "bun --filter '*' lint",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test"
  },
  "catalogs": {
    "main": {
      "@kobalte/core": "^0.13.11",
      "@modular-forms/solid": "^0.25.1",
      "@solidjs/router": "^0.15.4",
      "@solidjs/start": "2.0.0-alpha.2",
      "@solidjs/vite-plugin-nitro-2": "^0.1.0",
      "@tanstack/solid-query": "^5.100.14",
      "@tanstack/solid-table": "^8.21.3",
      "axios": "^1.16.1",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "corvu": "^0.7.2",
      "lucide-solid": "^1.16.0",
      "solid-js": "^1.9.12",
      "solid-sonner": "^0.3.1",
      "tailwind-merge": "^3.6.0",
      "valibot": "^1.4.1",
      "vite": "^7.3.3"
    },
    "dev": {
      "@kobalte/tailwindcss": "^0.9.0",
      "@tailwindcss/vite": "^4.3.0",
      "tailwindcss": "^4.3.0",
      "tw-animate-css": "^1.4.0",
      "typescript": "^5.6.0"
    }
  },
  "devDependencies": {
    "typescript": "catalog:dev"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14"
  }
}
